# ═══════════════════════════════════════════════════════════════════
# LOYALTY CENTRAL — .gitignore (Production-Grade / Banking Security)
# ═══════════════════════════════════════════════════════════════════

# ──────────────────── SECRETS & ENV FILES ────────────────────
# CRITICAL: Never commit secrets. This catches .env at ANY depth.
.env
.env.*
!.env.example

# ──────────────────── DEPENDENCIES ────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ──────────────────── PYTHON (loyalty-ai-backend) ────────────────────
**/venv/
**/.venv/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/

# ──────────────────── NEXT.JS / BUILD ────────────────────
/.next/
/out/
/build/

# ──────────────────── TESTING ────────────────────
/coverage/

# ──────────────────── TYPESCRIPT ────────────────────
*.tsbuildinfo
next-env.d.ts

# ──────────────────── SUPABASE LOCAL ────────────────────
supabase/.temp/

# ──────────────────── LOCK FILE DUPLICATES ────────────────────
# Keep only ONE lock file. If you use npm, ignore pnpm and vice versa.
pnpm-lock.yaml

# ──────────────────── OS FILES ────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~

# ──────────────────── IDE / EDITOR ────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ──────────────────── CERTIFICATES & KEYS ────────────────────
*.pem
*.key
*.p12
*.pfx
*.jks
*.crt
*.csr

# ──────────────────── DEBUG LOGS ────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ──────────────────── VERCEL ────────────────────
.vercel

# ──────────────────── LEGACY PROTOTYPES & DOCS ────────────────────
# HTML mockups from Stitch export (not part of the app)
b2b_dashboard.html
b2c_*.html
# Large planning document (451KB — not source code)
Puntos-mvp1-02.txt
