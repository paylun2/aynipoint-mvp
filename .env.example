# ═══════════════════════════════════════════════════════════════════
# LOYALTY CENTRAL — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# 
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env.local
# 2. Rellena los valores reales (NUNCA commits el .env.local)
# 3. Para Docker: cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════

# ──────────────────── SUPABASE ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ──────────────────── SITE CONFIG ────────────────────
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
NEXT_PUBLIC_ADMIN_DOMAIN=@tuempresa.com
NEXT_PUBLIC_ENFORCE_MFA=false

# ──────────────────── SECURITY / CRYPTO ────────────────────
QR_ENCRYPTION_KEY=your-min-16-char-key-here
CLAIM_JWT_SECRET=your-min-32-char-random-secret-here
JWT_SECRET=your-jwt-secret-here

# ──────────────────── RATE LIMITING (Upstash Redis) ────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx...

# ──────────────────── WHATSAPP (Meta Cloud API) ────────────────────
META_WHATSAPP_TOKEN=your-whatsapp-verify-token
META_APP_SECRET=your-meta-app-secret

# ──────────────────── PAYMENTS ────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
PREFER_STRIPE=false

# ──────────────────── ALERTAS DE SEGURIDAD ────────────────────
DISCORD_SECURITY_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx

# ──────────────────── DOCKER (solo para docker-compose) ────────────────────
POSTGRES_USER=ayni_admin
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=aynipoint_local
